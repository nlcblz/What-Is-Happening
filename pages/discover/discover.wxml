<!--pages/discover/discover.wxml-->
<view class="page">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrap">
      <view class="search-icon"></view>
      <input
        class="search-input"
        type="text"
        placeholder="搜索感兴趣的热点话题"
        placeholder-class="search-placeholder"
        value="{{searchValue}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search" />
    </view>
  </view>

  <!-- 分类标签栏 -->
  <scroll-view scroll-x class="category-bar" enhanced show-scrollbar="{{false}}">
    <view class="category-list">
      <view
        class="category-item {{activeCategory === item.id ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onCategoryTap">
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 搜索结果提示 -->
  <view class="search-result-bar" wx:if="{{searchActive}}">
    <text class="search-result-text" wx:if="{{searchResultCount > 0}}">找到 {{searchResultCount}} 条相关结果</text>
    <text class="search-result-text" wx:else>未找到相关结果</text>
  </view>

  <!-- 趋势卡片双列网格 -->
  <scroll-view
    scroll-y
    class="trend-scroll"
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="onLoadMore">

    <view class="trend-grid" wx:if="{{trends.length > 0}}">
      <!-- 左列 -->
      <view class="grid-column">
        <view class="grid-card" wx:for="{{leftCol}}" wx:key="id" bindtap="onTrendTap" data-id="{{item.id}}">
          <!-- 封面图 -->
          <image
            wx:if="{{item.imageUrl}}"
            class="card-image"
            src="{{item.imageUrl}}"
            mode="widthFix"
            lazy-load />
          <view class="card-body">
            <!-- 来源标签 -->
            <view class="card-source">
              <view class="source-tag {{item.category}}">{{item.sourceName}}</view>
            </view>
            <!-- 标题 -->
            <view class="card-title">{{item.title}}</view>
            <!-- 中文摘要 -->
            <view class="card-summary" wx:if="{{item.summaryZh}}">{{item.summaryZh}}</view>
            <!-- 底部：分类 + 时间 -->
            <view class="card-footer">
              <view class="category-tag">{{item.categoryLabel}}</view>
              <text class="time-ago">{{item.timeAgo}}</text>
            </view>
          </view>
        </view>
      </view>
      <!-- 右列 -->
      <view class="grid-column">
        <view class="grid-card" wx:for="{{rightCol}}" wx:key="id" bindtap="onTrendTap" data-id="{{item.id}}">
          <!-- 封面图 -->
          <image
            wx:if="{{item.imageUrl}}"
            class="card-image"
            src="{{item.imageUrl}}"
            mode="widthFix"
            lazy-load />
          <view class="card-body">
            <!-- 来源标签 -->
            <view class="card-source">
              <view class="source-tag {{item.category}}">{{item.sourceName}}</view>
            </view>
            <!-- 标题 -->
            <view class="card-title">{{item.title}}</view>
            <!-- 中文摘要 -->
            <view class="card-summary" wx:if="{{item.summaryZh}}">{{item.summaryZh}}</view>
            <!-- 底部：分类 + 时间 -->
            <view class="card-footer">
              <view class="category-tag">{{item.categoryLabel}}</view>
              <text class="time-ago">{{item.timeAgo}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-area" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && trends.length > 0 && !loading}}">
      <text class="no-more-text">-- 没有更多了 --</text>
    </view>

    <!-- 网络错误提示 -->
    <view class="network-error" wx:if="{{networkError && trends.length > 0}}">
      <text class="network-error-text">网络连接异常，显示的可能不是最新数据</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{trends.length === 0 && !loading}}">
      <view class="empty-icon-wrap">
        <view class="empty-compass"></view>
      </view>
      <text class="empty-text">暂无发现</text>
      <text class="empty-hint">下拉刷新探索最新热点趋势</text>
    </view>
  </scroll-view>
</view>
