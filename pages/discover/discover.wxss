/* pages/discover/discover.wxss */
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background-color: var(--bg-color);
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* ========== 搜索栏 ========== */
.search-bar {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  background-color: #ffffff;
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background-color: var(--bg-color);
  border-radius: 40rpx;
  padding: 14rpx 24rpx;
  gap: 12rpx;
}

.search-icon {
  width: 28rpx;
  height: 28rpx;
  flex-shrink: 0;
  border: 4rpx solid var(--text-hint);
  border-radius: 50%;
  position: relative;
}

.search-icon::after {
  content: '';
  position: absolute;
  width: 4rpx;
  height: 14rpx;
  background-color: var(--text-hint);
  bottom: -12rpx;
  right: -6rpx;
  transform: rotate(-45deg);
  border-radius: 2rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-primary);
  height: 40rpx;
  line-height: 40rpx;
}

.search-placeholder {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* ========== 分类标签栏 ========== */
.category-bar {
  flex-shrink: 0;
  background-color: #ffffff;
  border-bottom: 1rpx solid var(--border-color);
  white-space: nowrap;
}

.category-list {
  display: inline-flex;
  padding: 16rpx 24rpx 20rpx;
  gap: 16rpx;
}

.category-item {
  display: inline-block;
  padding: 10rpx 28rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background-color: var(--bg-color);
  transition: all 0.2s ease;
}

.category-item.active {
  color: #ffffff;
  background-color: var(--primary-color);
  font-weight: 500;
}

/* ========== 搜索结果提示 ========== */
.search-result-bar {
  flex-shrink: 0;
  padding: 16rpx 24rpx;
  background-color: var(--card-bg);
  border-bottom: 1rpx solid var(--border-color);
}

.search-result-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ========== 趋势卡片网格（双列） ========== */
.trend-scroll {
  flex: 1;
  height: 0;
}

.trend-grid {
  display: flex;
  padding: 16rpx 16rpx 0;
  gap: 16rpx;
}

.grid-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.grid-card {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-image {
  width: 100%;
  display: block;
  border-radius: 16rpx 16rpx 0 0;
}

.card-body {
  padding: 20rpx;
}

/* 来源标签 */
.card-source {
  margin-bottom: 12rpx;
}

.source-tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 500;
  color: #ffffff;
  background-color: var(--text-hint);
}

.source-tag.tech {
  background-color: #3498db;
}

.source-tag.international {
  background-color: #27ae60;
}

.source-tag.finance {
  background-color: #f39c12;
}

.source-tag.entertainment {
  background-color: #e74c3c;
}

.source-tag.society {
  background-color: #9b59b6;
}

/* 标题 */
.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 摘要 */
.card-summary {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 14rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 底部：分类 + 时间 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.category-tag {
  font-size: 20rpx;
  color: var(--text-hint);
  padding: 2rpx 12rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 6rpx;
}

.time-ago {
  font-size: 20rpx;
  color: var(--text-hint);
}

/* ========== 加载状态 ========== */
.loading-area {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

.no-more {
  padding: 40rpx;
  text-align: center;
}

.no-more-text {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* ========== 网络错误 ========== */
.network-error {
  margin: 16rpx;
  padding: 16rpx 24rpx;
  background-color: #fff3cd;
  border-radius: 12rpx;
  text-align: center;
}

.network-error-text {
  font-size: 24rpx;
  color: #856404;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 40rpx;
}

.empty-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: var(--bg-color);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-compass {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid var(--text-hint);
  border-radius: 50%;
  position: relative;
}

.empty-compass::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 4rpx;
  height: 24rpx;
  background-color: var(--primary-color);
  transform: translate(-50%, -100%) rotate(30deg);
  transform-origin: bottom center;
  border-radius: 2rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-hint);
}
