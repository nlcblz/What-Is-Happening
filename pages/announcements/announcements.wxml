<!--pages/announcements/announcements.wxml-->
<view class="page">
  <scroll-view
    scroll-y
    class="post-scroll"
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onPullDownRefresh"
    bindscrolltolower="onReachBottom">

    <!-- 公告列表 -->
    <view class="post-list" wx:if="{{posts.length > 0}}">
      <view 
        class="post-card" 
        wx:for="{{posts}}" 
        wx:key="id" 
        bindtap="onPostTap" 
        data-id="{{item.id}}">
        <!-- 封面图 -->
        <image 
          wx:if="{{item.coverUrl}}" 
          class="post-cover" 
          src="{{item.coverUrl}}" 
          mode="aspectFill" />
        <view class="post-body">
          <!-- 标题 -->
          <view class="post-title">{{item.title}}</view>
          <!-- 摘要 -->
          <view class="post-summary" wx:if="{{item.summary}}">{{item.summary}}</view>
          <!-- 底部信息 -->
          <view class="post-footer">
            <text class="post-author">{{item.author}}</text>
            <text class="post-time">{{item.timeAgo}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-area" wx:if="{{loading}}">
      <text class="loading-text">加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && posts.length > 0 && !loading}}">
      <text class="no-more-text">— 没有更多了 —</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{posts.length === 0 && !loading}}">
      <text class="empty-icon">📢</text>
      <text class="empty-text">暂无公告</text>
      <text class="empty-hint">管理员还没有发布任何内容</text>
    </view>
  </scroll-view>
</view>
