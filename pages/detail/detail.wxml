<!--pages/detail/detail.wxml-->
<view class="page">
  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 错误状态 -->
  <view class="error-state" wx:elif="{{error}}">
    <text class="error-icon">😵</text>
    <text class="error-text">加载失败</text>
    <text class="error-hint">请返回重试</text>
  </view>

  <!-- 详情内容 -->
  <view class="detail-content" wx:elif="{{trend}}">
    <!-- 顶部标签区域：来源 + 分类 -->
    <view class="tag-row">
      <view class="source-tag {{trend.category}}">{{trend.sourceName}}</view>
      <view class="category-tag">{{categoryLabel}}</view>
    </view>

    <!-- 标题 -->
    <view class="detail-title">{{trend.title}}</view>

    <!-- 发布时间 -->
    <view class="time-row">
      <text class="time-label">发布于</text>
      <text class="time-value">{{publishTime}}</text>
      <text class="time-ago">（{{timeAgo}}）</text>
    </view>

    <!-- 封面图 -->
    <image
      wx:if="{{trend.imageUrl}}"
      class="detail-image"
      src="{{trend.imageUrl}}"
      mode="widthFix" />

    <!-- 中文摘要 -->
    <view class="summary-section" wx:if="{{trend.summaryZh}}">
      <view class="section-title">📝 AI 摘要</view>
      <view class="summary-text">{{trend.summaryZh}}</view>
    </view>

    <!-- 翻译开关（仅当有全文内容且非中文时显示） -->
    <view class="translate-toggle" wx:if="{{hasContent && needsTranslation}}">
      <view class="toggle-left">
        <text class="toggle-label">🌐 显示中文翻译</text>
        <text class="toggle-hint">AI双语对照</text>
      </view>
      <switch
        class="toggle-switch"
        checked="{{showTranslation}}"
        bindchange="onToggleTranslation"
        disabled="{{translating}}"
        color="#3b82f6" />
    </view>

    <!-- 翻译中提示 -->
    <view class="translating-hint" wx:if="{{translating}}">
      <text class="translating-text">正在翻译中，请稍候...</text>
    </view>

    <!-- 全文内容区域 -->
    <view class="content-section" wx:if="{{hasContent}}">
      <view class="section-title">📄 全文内容</view>
      
      <!-- 双语对照模式 -->
      <block wx:if="{{showTranslation && paragraphs.length > 0}}">
        <view class="bilingual-block" wx:for="{{paragraphs}}" wx:key="index">
          <view class="para-en">{{item.en}}</view>
          <view class="para-zh">{{item.zh}}</view>
        </view>
      </block>

      <!-- 原文模式（不翻译或中文内容） -->
      <block wx:else>
        <view class="content-text">{{trend.content}}</view>
      </block>
    </view>

    <!-- 英文摘要（如有且无全文） -->
    <view class="summary-section" wx:if="{{!hasContent && trend.summary && trend.summary !== trend.summaryZh}}">
      <view class="section-title">📄 原文摘要</view>
      <view class="summary-text summary-en">{{trend.summary}}</view>
    </view>

    <!-- 原文链接 -->
    <view class="link-section" wx:if="{{trend.url}}">
      <view class="section-title">🔗 原文链接</view>
      <view class="link-row">
        <text class="link-text" selectable>{{trend.url}}</text>
        <view class="copy-btn" bindtap="onCopyLink">复制链接</view>
      </view>
    </view>

    <!-- 底部信息 -->
    <view class="detail-footer">
      <text class="footer-hint">微信小程序内无法直接打开链接，请复制后在浏览器中访问</text>
    </view>
  </view>
</view>
