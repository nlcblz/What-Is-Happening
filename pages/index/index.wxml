<!--pages/index/index.wxml-->
<view class="page">
  <!-- 分类标签栏 -->
  <scroll-view scroll-x class="category-bar" enhanced show-scrollbar="{{false}}">
    <view class="category-list">
      <view
        class="category-item {{activeCategory === item.id ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="id"
        data-id="{{item.id}}"
        bindtap="onCategoryTap">
        {{item.name}}
      </view>
    </view>
  </scroll-view>

  <!-- 趋势卡片列表 -->
  <scroll-view
    scroll-y
    class="trend-scroll"
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onPullDownRefresh"
    bindscrolltolower="onReachBottom">

    <view class="trend-list">
      <view class="trend-card" wx:for="{{trends}}" wx:key="id">
        <!-- 来源标签 + 时间 -->
        <view class="card-meta">
          <view class="source-tag {{item.category}}">{{item.sourceName}}</view>
          <text class="time-ago">{{item.timeAgo}}</text>
        </view>
        <!-- 标题 -->
        <view class="card-title">{{item.title}}</view>
        <!-- 中文摘要 -->
        <view class="card-summary" wx:if="{{item.summaryZh}}">{{item.summaryZh}}</view>
        <!-- 分类标签 -->
        <view class="card-footer">
          <view class="category-tag">{{item.category === 'tech' ? '科技' : '国际'}}</view>
        </view>
      </view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-area" wx:if="{{loading}}">
      <text class="loading-text">加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore && trends.length > 0 && !loading}}">
      <text class="no-more-text">— 没有更多了 —</text>
    </view>

    <!-- 网络错误提示 -->
    <view class="network-error" wx:if="{{networkError && trends.length > 0}}">
      <text class="network-error-text">⚠️ 网络连接异常，显示的可能不是最新数据</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{trends.length === 0 && !loading}}">
      <text class="empty-icon">📭</text>
      <text class="empty-text">暂无热点</text>
      <text class="empty-hint">下拉刷新获取最新趋势</text>
    </view>
  </scroll-view>
</view>
