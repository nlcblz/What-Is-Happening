/* pages/post-detail/post-detail.wxss */
.page {
  min-height: 100vh;
  background-color: var(--bg-color);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 加载状态 */
.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 400rpx;
  padding-top: 200rpx;
}

.loading-text {
  color: var(--text-hint);
  font-size: 28rpx;
}

/* 错误状态 */
.error-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 32rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.error-hint {
  font-size: 26rpx;
  color: var(--text-hint);
}

/* 详情内容 */
.detail-content {
  padding: 32rpx;
}

.detail-cover {
  width: 100%;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
}

.detail-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.4;
  margin-bottom: 20rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  margin-bottom: 32rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid var(--border-color);
}

.meta-author {
  font-size: 26rpx;
  color: var(--primary-color);
  margin-right: 20rpx;
}

.meta-time {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.meta-ago {
  font-size: 24rpx;
  color: var(--text-hint);
}

/* 正文内容 */
.content-section {
  background-color: var(--card-bg);
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.content-text {
  font-size: 30rpx;
  color: var(--text-primary);
  line-height: 1.9;
  white-space: pre-wrap;
  word-break: break-word;
}

.content-empty {
  text-align: center;
  padding: 40rpx;
  color: var(--text-hint);
  font-size: 28rpx;
}
